{
  "rewrites": [
    {
      "source": "/(?!.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|webp|mp4)$)(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*\\.mp4)",
      "headers": [
        { "key": "Content-Type", "value": "video/mp4" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Accept-Ranges", "value": "bytes" }
      ]
    }
  ]
}
